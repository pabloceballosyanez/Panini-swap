# Panini Swap — Environment Variables
# Copy to .env and fill in your values

# API Key for admin endpoints (change this!)
PANINI_API_KEY=panini-swap-2026-secret

# Port (optional, defaults to 3456)
PORT=3456

# Telegram Bot Token (from @BotFather)
PANINI_TELEGRAM_TOKEN=

# Public URL of the app (for Telegram webhook setup)
# Local dev: use ngrok, e.g. https://abc123.ngrok.io
# Production: https://your-app.onrender.com
PANINI_APP_URL=http://localhost:3456

# Note: the webhook secret is auto-set to the bot token value.
# Telegram sends X-Telegram-Bot-Api-Secret-Token header with each update.
